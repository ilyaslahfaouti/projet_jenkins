pipeline {
    agent any

    // 1. AJOUT : On déclare l'outil Maven pour que Jenkins sache exécuter la commande 'mvn'
    // Note : Les noms doivent correspondre à ceux configurés dans "Administrer Jenkins > Tools"
    tools {
        maven 'Maven3'
    }

    stages {
        stage('Checkout') {
            steps {
                // Récupère le code depuis le SCM configuré dans Jenkins
                checkout scm
            }
        }

        stage('Build') {
            steps {
                // 2. AJOUT : On se déplace dans le bon dossier avant de lancer les commandes
                dir('ICDE848') {
                    script {
                        if (isUnix()) {
                            sh '''
                                # Find Java if JAVA_HOME is not set
                                if [ -z "$JAVA_HOME" ]; then
                                    export JAVA_HOME=$(readlink -f /usr/bin/java | sed "s:bin/java::")
                                fi
                                # Run Maven
                                mvn clean compile -B
                            '''
                        } else {
                            bat 'mvn clean compile -B'
                        }
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                // On n'oublie pas le dir() ici aussi
                dir('ICDE848') {
                    script {
                        if (isUnix()) {
                            sh '''
                                if [ -z "$JAVA_HOME" ]; then
                                    export JAVA_HOME=$(readlink -f /usr/bin/java | sed "s:bin/java::")
                                fi
                                mvn test -B
                            '''
                        } else {
                            bat 'mvn test -B'
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Jacoco') {
            steps {
                // Analyse de la couverture de code avec Jacoco
                dir('ICDE848') {
                    script {
                        if (isUnix()) {
                            sh '''
                                if [ -z "$JAVA_HOME" ]; then
                                    export JAVA_HOME=$(readlink -f /usr/bin/java | sed "s:bin/java::")
                                fi
                                mvn verify -B -DskipTests
                            '''
                        } else {
                            bat 'mvn verify -B -DskipTests'
                        }
                    }
                }
            }
            post {
                always {
                    // Archive les rapports de couverture Jacoco (plugin jacoco non installé)
                    archiveArtifacts allowEmptyArchive: true, artifacts: '**/target/jacoco.exec,**/target/site/jacoco/**'
                }
            }
        }

        stage('SpotBugs') {
            steps {
                // Analyse des bugs avec SpotBugs
                dir('ICDE848') {
                    script {
                        if (isUnix()) {
                            sh '''
                                if [ -z "$JAVA_HOME" ]; then
                                    export JAVA_HOME=$(readlink -f /usr/bin/java | sed "s:bin/java::")
                                fi
                                mvn spotbugs:check -B
                            '''
                        } else {
                            bat 'mvn spotbugs:check -B'
                        }
                    }
                }
            }
            post {
                always {
                    // Rend le rapport disponible dans les artefacts au lieu d'utiliser le plugin Warnings NG qui n'est pas installé
                    archiveArtifacts allowEmptyArchive: true, artifacts: '**/spotbugsXml.xml'
                }
            }
        }

        stage('Checkstyle') {
            steps {
                // Et le dir() ici également
                dir('ICDE848') {
                    script {
                        if (isUnix()) {
                            sh '''
                                if [ -z "$JAVA_HOME" ]; then
                                    export JAVA_HOME=$(readlink -f /usr/bin/java | sed "s:bin/java::")
                                fi
                                mvn checkstyle:checkstyle -B -Dcheckstyle.config.location=checkstyle.xml
                            '''
                        } else {
                            bat 'mvn checkstyle:checkstyle -B -Dcheckstyle.config.location=checkstyle.xml'
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts allowEmptyArchive: true, artifacts: '**/target/checkstyle-result.xml'
                }
            }
        }
    }

    post {
        failure {
            script {
                echo "Le build a échoué. Envoi de l'email d'alerte..."
                // Utiliser le plugin email intégré de Jenkins
                emailext (
                    subject: "❌ Jenkins Build FAILURE - ${env.JOB_NAME}",
                    body: """
                        Le build Jenkins a échoué.
                        
                        Job: ${env.JOB_NAME}
                        Build: ${env.BUILD_NUMBER}
                        
                        URL: ${env.BUILD_URL}
                        Log: ${env.BUILD_URL}console
                        
                        Merci de vérifier les logs pour plus de détails.
                    """,
                    to: '${DEFAULT_RECIPIENTS}',
                    mimeType: 'text/plain'
                )
                
                // Essayer aussi d'envoyer avec le script Python si disponible
                if (isUnix()) {
                    sh '''
                        if command -v python3 &> /dev/null; then
                            echo "Python3 trouvé, envoi via script..."
                            python3 ICDE848/send_email.py failure "${BUILD_URL}" "${JOB_NAME}" || true
                        else
                            echo "Python3 non trouvé, email déjà envoyé via plugin Jenkins"
                        fi
                    '''
                }
            }
        }
        fixed {
            script {
                echo "Le build est de nouveau stable après une erreur. Envoi de l'email..."
                emailext (
                    subject: "✅ Jenkins Build FIXED - ${env.JOB_NAME}",
                    body: """
                        Le build Jenkins est de nouveau stable (Corrigé).
                        
                        Job: ${env.JOB_NAME}
                        Build: ${env.BUILD_NUMBER}
                        
                        URL: ${env.BUILD_URL}
                        
                        Bravo !
                    """,
                    to: '${DEFAULT_RECIPIENTS}',
                    mimeType: 'text/plain'
                )
                
                // Essayer aussi d'envoyer avec le script Python si disponible
                if (isUnix()) {
                    sh '''
                        if command -v python3 &> /dev/null; then
                            echo "Python3 trouvé, envoi via script..."
                            python3 ICDE848/send_email.py fixed "${BUILD_URL}" "${JOB_NAME}" || true
                        else
                            echo "Python3 non trouvé, email déjà envoyé via plugin Jenkins"
                        fi
                    '''
                }
            }
        }
    }
}